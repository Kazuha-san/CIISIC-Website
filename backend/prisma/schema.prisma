generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  name                String
  role                Role
  passwordHash        String?
  emailVerified       Boolean              @default(false)
  isActive            Boolean              @default(true)
  avatarUrl           String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  accounts            Account[]
  auditLogs           AuditLog[]
  reviewedChallenges  Challenge[]          @relation("ChallengeReviewer")
  industryProfile     IndustryProfile?
  institutionProfile  InstitutionProfile?
  sentMessages        Message[]            @relation("SentMessages")
  notifications       Notification[]
  passwordResetTokens PasswordResetToken[]
  sessions            Session[]
  studentProfile      StudentProfile?

  @@index([email])
  @@index([role])
}

model StudentProfile {
  id            String      @id @default(cuid())
  userId        String      @unique
  enrollmentNo  String      @unique
  institutionId String
  department    String
  yearOfStudy   Int
  skills        String[]
  createdAt     DateTime    @default(now())
  proposals     Proposal[]
  institution   Institution @relation(fields: [institutionId], references: [id])
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model IndustryProfile {
  id          String      @id @default(cuid())
  userId      String      @unique
  companyName String
  industry    String
  logoUrl     String?
  websiteUrl  String?
  isCIIMember Boolean     @default(false)
  memberSince DateTime?
  createdAt   DateTime    @default(now())
  challenges  Challenge[]
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Institution {
  id                 String              @id @default(cuid())
  name               String              @unique
  city               String
  state              String              @default("Madhya Pradesh")
  logoUrl            String?
  websiteUrl         String?
  cellTheme          CellTheme?
  spocUserId         String?
  createdAt          DateTime            @default(now())
  institutionProfile InstitutionProfile?
  students           StudentProfile[]
}

model InstitutionProfile {
  id            String      @id @default(cuid())
  userId        String      @unique
  institutionId String      @unique
  designation   String
  department    String
  createdAt     DateTime    @default(now())
  institution   Institution @relation(fields: [institutionId], references: [id])
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Challenge {
  id                String          @id @default(cuid())
  title             String
  description       String
  problemStatement  String
  domain            CellTheme
  status            ChallengeStatus @default(DRAFT)
  deadline          DateTime
  budgetRange       String?
  industryProfileId String
  attachmentUrls    String[]
  tags              String[]
  viewCount         Int             @default(0)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  publishedAt       DateTime?
  organizationName  String?
  duration          String?
  reviewRemarks     String?
  reviewedAt        DateTime?
  reviewerId        String?
  industryProfile   IndustryProfile @relation(fields: [industryProfileId], references: [id])
  reviewer          User?           @relation("ChallengeReviewer", fields: [reviewerId], references: [id])
  proposals         Proposal[]

  @@index([status])
  @@index([domain])
  @@index([deadline])
}

model Proposal {
  id                 String         @id @default(cuid())
  challengeId        String
  studentProfileId   String
  status             ProposalStatus @default(SUBMITTED)
  approachDoc        String?
  summary            String
  revisionNotes      String?
  feedbackByIndustry String?
  submittedAt        DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  messages           Message[]
  challenge          Challenge      @relation(fields: [challengeId], references: [id])
  studentProfile     StudentProfile @relation(fields: [studentProfileId], references: [id])

  @@unique([challengeId, studentProfileId])
  @@index([status])
}

model Message {
  id            String      @id @default(cuid())
  proposalId    String
  senderId      String
  type          MessageType @default(QUERY)
  body          String
  attachmentUrl String?
  isSystemMsg   Boolean     @default(false)
  createdAt     DateTime    @default(now())
  proposal      Proposal    @relation(fields: [proposalId], references: [id])
  sender        User        @relation("SentMessages", fields: [senderId], references: [id])

  @@index([proposalId])
  @@index([senderId])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  entityType String
  entityId   String
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

enum Role {
  SUPER_ADMIN
  CII_ADMIN
  INSTITUTION_SPOC
  INDUSTRY_SPOC
  STUDENT
}

enum CellTheme {
  FAMILY_BUSINESS
  TALENT_READINESS
  RESEARCH_INNOVATION
  AI_IN_BUSINESS
  AGRITECH
  SKILL_DEVELOPMENT
  STARTUP
}

enum ChallengeStatus {
  DRAFT
  OPEN
  UNDER_REVIEW
  CLOSED
  ARCHIVED
  PENDING_APPROVAL
  REJECTED
}

enum ProposalStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  REVISION_REQUESTED
  RESUBMITTED
  APPROVED
  REJECTED
}

enum MessageType {
  QUERY
  RESPONSE
  SYSTEM_NOTICE
}
